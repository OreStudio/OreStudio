@startuml

title ores.qt.workflow Component

set namespaceSeparator ::

namespace ores #F2F2F2 {
    namespace qt #F2F2F2 {
        class WorkflowController {
            +parent : QObject*
            -mainWindow_ : QMainWindow*
            -mdiArea_ : QMdiArea*
            -clientManager_ : ClientManager*
            -listWindow_ : QPointer<WorkflowMdiWindow>
            -listSubWindow_ : QPointer<DetachableMdiSubWindow>
            -defsWindow_ : QPointer<WorkflowDefinitionMdiWindow>
            -defsSubWindow_ : QPointer<DetachableMdiSubWindow>
        }
        class WorkflowDefinitionMdiWindow {
            +parent : QWidget*
            -clientManager_ : ClientManager*
            -toolbar_ : QToolBar*
            -refreshAction_ : QAction*
            -definitionTable_ : QTableWidget*
            -splitter_ : QSplitter*
            -stepsGroup_ : QGroupBox*
            -stepsTable_ : QTableWidget*
            -watcher_ : QFutureWatcher<FetchResult>*
        }
        class WorkflowInstanceDetailDialog {
            +parent : QWidget*
            -clientManager_ : ClientManager*
            -workflowId_ : QString
            -workflowType_ : QString
            -workflowStatus_ : QString
            -statusLabel_ : QLabel*
            -stepsWidget_ : WorkflowStepsWidget*
            -logWidget_ : WorkflowStepLogWidget*
        }
        class WorkflowMdiWindow {
            +parent : QWidget*
            -clientManager_ : ClientManager*
            -toolbar_ : QToolBar*
            -refreshAction_ : QAction*
            -autoRefreshAction_ : QAction*
            -autoRefreshTimer_ : QTimer*
            -tabs_ : QTabWidget*
            -activeCountLabel_ : QLabel*
            -failedCountLabel_ : QLabel*
            -failuresTable_ : QTableWidget*
            -searchEdit_ : QLineEdit*
            -statusFilter_ : QComboBox*
            -instanceTable_ : QTableWidget*
            -splitter_ : QSplitter*
            -stepsGroup_ : QGroupBox*
            -stepsTable_ : QTableWidget*
            -watcher_ : QFutureWatcher<FetchResult>*
            -currentInstances_ : vector<ores::workflow::messaging::workflow_instance_summary>
            -stepsWatcher_ : QFutureWatcher<StepsFetchResult>*
            -selectedInstanceId_ : QString
            -currentSteps_ : vector<ores::workflow::messaging::workflow_step_summary>
        }
        class WorkflowPlugin {
            -ctx_ : plugin_context
            -controller_ : unique_ptr<WorkflowController>
        }
        class WorkflowStepLogWidget {
            -headerLabel_ : QLabel*
            -logTable_ : QTableWidget*
        }
        class WorkflowStepsWidget {
            +parent : QWidget*
            -clientManager_ : ClientManager*
            -instanceId_ : QUuid
            -headerLabel_ : QLabel*
            -stepsTable_ : QTableWidget*
            -refreshTimer_ : QTimer*
            -watcher_ : QFutureWatcher<FetchResult>*
            -maxVisibleSteps_ : int
            -terminalReached_ : bool
            -currentSteps_ : vector<ores::workflow::messaging::workflow_step_summary>
        }
    }
}

