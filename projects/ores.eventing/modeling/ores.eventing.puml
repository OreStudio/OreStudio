@startuml

title ores.eventing Component

set namespaceSeparator ::

namespace ores #F2F2F2 {
    namespace eventing #F2F2F2 {
        namespace domain #F2F2F2 {
            class entity_change_event <<struct>> {
                +entity : string
                +timestamp : chrono::system_clock::time_point
                +entity_ids : vector<string>
                +tenant_id : string
            }
            class event_channel_info <<struct>> {
                +name : string
                +description : string
            }
        }
        namespace generators #F2F2F2 {
            class entity_change_event_generator {
            }
        }
        namespace service #F2F2F2 {
            class subscription {
                -unsubscribe_ : unsubscribe_fn
            }
            class event_bus {
                -mutex_ : mutable mutex
                -subscribers_ : subscriber_map
                -next_subscriber_id_ : subscriber_id
            }
            class event_channel_registry {
                -mutex_ : mutable mutex
                -channels_ : unordered_map<string, domain::event_channel_info>
            }
            class postgres_event_source {
                -bus_ : event_bus&
                -listener_ : ores::database::service::postgres_listener_service
                -entity_mappings_ : unordered_map<string, entity_mapping>
            }
            class registrar {
            }
        }
    }
}

' --- manual: everything below this line is hand-authored; the script preserves it ---

