@startuml

title ores.compute.service Component

set namespaceSeparator ::

namespace ores #F2F2F2 {
    namespace compute #F2F2F2 {
        namespace service #F2F2F2 {

            namespace app #F2F2F2 {
                class application {
                    + run(io_ctx: io_context&, cfg: options): awaitable<void>
                    - make_context(db_opts: database_options): context
                }
            }

            namespace messaging #F2F2F2 {
                class host_handler {
                    + handle_list(req): response
                    + handle_save(req): response
                }
                class app_handler {
                    + handle_list(req): response
                    + handle_save(req): response
                }
                class app_version_handler {
                    + handle_list(req): response
                    + handle_save(req): response
                }
                class batch_handler {
                    + handle_list(req): response
                    + handle_save(req): response
                }
                class workunit_handler {
                    + handle_list(req): response
                    + handle_save(req): response
                }
                class result_handler {
                    + handle_list(req): response
                    + handle_submit(req): response
                }
                class work_handler {
                    + pull(msg): void
                    + heartbeat(msg): void
                    + reap(msg): void
                }
                class registrar {
                    + register_all(nats: client&, db: context&): void
                }
            }

            namespace config #F2F2F2 {
                class options {
                    + logging: optional<logging_options>
                    + nats: nats_options
                    + database: database_options
                }
                class parser {
                    + {static} parse(argc: int, argv: char**): options
                }
            }

            app::application --> messaging::registrar : uses
            app::application --> config::options : configured by
            messaging::registrar --> messaging::host_handler : registers
            messaging::registrar --> messaging::app_handler : registers
            messaging::registrar --> messaging::app_version_handler : registers
            messaging::registrar --> messaging::batch_handler : registers
            messaging::registrar --> messaging::workunit_handler : registers
            messaging::registrar --> messaging::result_handler : registers
            messaging::registrar --> messaging::work_handler : registers
        }
    }
}

@enduml
