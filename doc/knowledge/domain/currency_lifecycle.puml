@startuml
!pragma layout smetana

title Currency lifecycle

skinparam state {
    BackgroundColor #D6E8FA
    BorderColor #4A78A8
    FontColor #1A1A1E
    AttributeFontColor #3A3A3E
    ArrowColor #4A78A8
    ArrowFontColor #1A1A1E
    StartColor #4A78A8
    EndColor #4A78A8
}
skinparam note {
    BackgroundColor #FBF3D3
    BorderColor #C9A227
    FontColor #1A1A1E
}
skinparam BackgroundColor white
skinparam DefaultFontColor #1A1A1E

state "Created" as Created
state "Circulating" as Circulating
state "Withdrawn" as Withdrawn <<end>>

[*] --> Created : issuing authority\nintroduces the currency
Created --> Circulating : enters general use
Circulating --> Circulating : redenomination /\nmonetary union event
Circulating --> Withdrawn : replaced, absorbed,\nor discontinued

note right of Circulating
  The same shape repeats one
  level down for denominations,
  and again for individual
  note/coin instances -- the
  lifecycle is fractal.
end note

note right of Withdrawn
  Records of transactions made
  during the currency's life
  must still be retained after
  withdrawal.
end note

@enduml
