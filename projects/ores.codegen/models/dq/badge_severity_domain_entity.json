    "primary_key": {
      "column": "code",
      "type": "text",
      "cpp_type": "std::string",
      "description": "Unique severity code.",
      "detail": "Examples: 'secondary', 'info', 'success', 'warning', 'danger', 'primary'."
    },

    "natural_keys": [
      {
        "column": "name",
        "type": "text",
        "cpp_type": "std::string",
        "description": "Human-readable name for the severity level.",
        "generator_expr": "std::string(faker::word::adjective()) + \" Severity\""
      }
    ],

    "columns": [
      {
        "name": "description",
        "type": "text",
        "cpp_type": "std::string",
        "nullable": false,
        "description": "Detailed description of the severity level.",
        "generator_expr": "std::string(faker::lorem::sentence())"
      },
      {
        "name": "display_order",
        "type": "integer",
        "cpp_type": "int",
        "nullable": false,
        "description": "Order for UI display purposes.",
        "generator_expr": "faker::number::integer(1, 100)"
      }
    ],

    "sql": {
      "tablename": "ores_dq_badge_severities_tbl"
    },

    "repository": {
      "entity_singular_short": "severity",
      "entity_plural_short": "severities",
