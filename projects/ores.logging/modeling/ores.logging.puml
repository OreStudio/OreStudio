@startuml

title ores.logging Component

set namespaceSeparator ::

namespace ores #F2F2F2 {
    namespace logging #F2F2F2 {
        enum boost_severity {
            trace
            debug
            info
            warn
            error
        }
        class lifecycle_manager {
            #file_sink_ : boost::shared_ptr<file_sink_type>
            #console_sink_ : boost::shared_ptr<console_sink_type>
        }
        class logging_configuration {
        }
        class logging_options <<struct>> {
            +severity : string
            +filename : string
            +output_to_console : bool
            +output_directory : filesystem::path
            +include_pid : bool
            +replica_index : optional<int>
            +tag : string
        }
        class logging_options_validator {
        }
        class scoped_attribute {
            -iterator_ : optional<iterator>
        }
        enum severity_level {
            trace
            debug
            info
            warn
            error
            fatal
        }
    }
}

