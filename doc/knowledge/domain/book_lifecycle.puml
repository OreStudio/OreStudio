@startuml
!pragma layout smetana

title Book lifecycle

skinparam state {
    BackgroundColor #2A2A2E
    BorderColor #58A6FF
    FontColor #E3E3E6
    AttributeFontColor #A1A1AA
    ArrowColor #8AB4F8
    ArrowFontColor #E3E3E6
    StartColor #58A6FF
    EndColor #58A6FF
}
skinparam note {
    BackgroundColor #1A1A1E
    BorderColor #58A6FF
    FontColor #E3E3E6
}
skinparam BackgroundColor transparent
skinparam DefaultFontColor #E3E3E6

state "Initiated" as Initiated
state "Pending controller review" as ControllerReview
state "Pending enrichment" as Enrichment {
    state "Finance" as EnrichFinance
    state "Market Risk" as EnrichRisk
    state "Operations" as EnrichOps
    [*] --> EnrichFinance
    [*] --> EnrichRisk
    [*] --> EnrichOps
}
state "Pending approval" as Approval
state "Pending access review" as AccessReview
state "Live" as Live
state "Pending clean-down" as CleanDown
state "Closed" as Closed <<end>>

[*] --> Initiated : desk authorises
Initiated --> ControllerReview
ControllerReview --> Enrichment : approved
Enrichment --> Approval : all 3 functions enrich
Approval --> AccessReview : each enricher approves\ntheir own changes
AccessReview --> Live : book set up on\nbooking systems

Live --> Live : deal moves in/out\n(book move, undo book move,\nintra-book hedging)
Live --> Live : access review lapses\n(monthly/quarterly) --\nre-request to stay Live

Live --> CleanDown : close requested
CleanDown --> Live : not flat --\nmove/settle remaining balances
CleanDown --> Closed : flat -- all live deals\nmoved out, book\nactioned through accounting

note right of ControllerReview
  Ledger book setup for the
  book (see Book and the ledger)
  happens alongside this stage.
end note

note right of Enrichment
  Each enriching function
  approves its own changes
  before Approval can complete.
end note

note right of CleanDown
  Gate: a book can only be
  closed if it is flat -- every
  balance held against it is
  zero on that business date.
end note

note right of Closed
  Never physically deleted --
  moved to the Root Book /
  Recycle Bin mechanism.
end note

@enduml
