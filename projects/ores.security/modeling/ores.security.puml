@startuml

title ores.security Component

set namespaceSeparator ::

namespace jwt #F2F2F2 {
    namespace traits #F2F2F2 {
        class boost_json <<struct>> {
        }
    }
}
namespace ores #F2F2F2 {
    namespace security #F2F2F2 {
        namespace crypto #F2F2F2 {
            class encryption {
            }
            class password_hasher {
            }
        }
        namespace jwt #F2F2F2 {
            class jwt_authenticator {
                +audience : const string&
                +audience : const string&
                +audience : const string&
                -configured_ : bool
                -algorithm_ : algorithm_type
                -secret_ : string
                -private_key_ : string
                -public_key_ : string
                -issuer_ : string
                -audience_ : string
            }
            class jwt_claims <<struct>> {
                +subject : string
                +issuer : string
                +audience : string
                +expires_at : chrono::system_clock::time_point
                +issued_at : chrono::system_clock::time_point
                +roles : vector<string>
                +username : optional<string>
                +email : optional<string>
                +session_id : optional<string>
                +session_start_time : optional<chrono::system_clock::time_point>
                +tenant_id : optional<string>
                +party_id : optional<string>
                +visible_party_ids : vector<string>
            }
            enum jwt_error {
                invalid_token
                expired_token
                invalid_signature
                missing_claims
                invalid_issuer
                invalid_audience
            }
        }
        namespace validation #F2F2F2 {
            class email_validator {
            }
            class password_validator {
                +enforce_policy : bool
            }
            class validation_result <<struct>> {
                +is_valid : bool
                +error_message : string
            }
        }
    }
}

