namespace OresCodegenCppProtocol

// UVL model of entity_meta_model_cpp_protocol.org: the four standard
// message pairs (get/save/delete/history) are mandatory; custom message
// types and their includes are independent optional choices.

features
    CppProtocol {abstract}
        mandatory
            StandardMessagePairs
        optional
            HasCustomMessageIncludes
            HasCustomMessageTypes
