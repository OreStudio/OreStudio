@startuml
!pragma layout smetana

title ORE Studio System Architecture

note as SystemNote
C++23 application providing persistent storage, graphical interface,
and orchestration tools for Open Source Risk Engine (ORE).
end note

' ─────────────────────────────────────────────────────────────────────────────
' Foundation Layer
' ─────────────────────────────────────────────────────────────────────────────
package "Foundation Layer" #F2F2F2 {
    component [ores.utility] as utility #F7E5FF
    note right of utility
    Foundation utilities: UUID v7, Base64/32, datetime,
    faker, rfl reflectors, streaming operators.
    No ORE Studio dependencies.
    end note

    component [ores.platform] as platform #F7E5FF
    note right of platform
    OS abstractions: environment vars, filesystem,
    hostname/MAC/machine-ID, cross-platform time.
    end note

    component [ores.logging] as logging #F7E5FF
    note right of logging
    Core Boost.Log infrastructure: make_logger(),
    severity levels, lifecycle manager for sinks.
    Extracted from ores.telemetry to break circular dep.
    end note

    component [ores.telemetry] as telemetry #F7E5FF
    note right of telemetry
    Extends logging with distributed tracing,
    OpenTelemetry integration, JSON Lines export.
    end note

    component [ores.database] as database #F7E5FF
    note right of database
    PostgreSQL access: connection pool, tenant/party
    context, bitemporal CRUD, health monitor,
    LISTEN/NOTIFY integration.
    end note

    component [ores.variability] as variability #F7E5FF
    note right of variability
    Feature flags and runtime configuration.
    variability.v1.> NATS namespace.
    end note

    component [ores.geo] as geo #F7E5FF
    note right of geo
    IP-to-location via MaxMind GeoLite2-City in
    PostgreSQL. Used by ores.iam for session tracking.
    end note

    component [ores.security] as security #F7E5FF
    note right of security
    Crypto primitives: scrypt hashing, AES-256-GCM,
    JWT validation, OWASP password/email validators.
    end note
}

' ─────────────────────────────────────────────────────────────────────────────
' Infrastructure Layer
' ─────────────────────────────────────────────────────────────────────────────
package "Infrastructure Layer" #F2F2F2 {
    component [ores.nats] as nats #F7E5FF
    note right of nats
    NATS transport: request/reply, queue-group
    subscribe, JetStream. JSON payloads via rfl.
    Subject: {domain}.v1.{entity}.{operation}.
    Replaced ores.comms binary protocol.
    end note

    component [ores.service] as svc #F7E5FF
    note right of svc
    NATS service runner: domain_service_runner,
    heartbeat publisher, request context,
    handler helpers. All *.service entrypoints
    build on this library.
    end note

    component [ores.eventing] as eventing #F7E5FF
    note right of eventing
    In-process pub/sub event bus with PostgreSQL
    LISTEN/NOTIFY bridge for cross-service events.
    end note

    component [ores.testing] as testing #F7E5FF
    note right of testing
    Catch2 infrastructure: unique DB per process,
    logging/database lifecycle listeners,
    tenant RLS helpers, coroutine test support.
    end note

    component [ores.assets] as assets #F7E5FF
    note right of assets
    Binary image storage with hierarchical tagging
    and currency-to-image linking.
    assets.v1.> NATS namespace.
    end note

    component [ores.http.api] as httpapi #F7E5FF
    note right of httpapi
    HTTP server infra: Boost.Beast/Asio async
    server, JWT auth middleware, path-based
    router, OpenAPI registry.
    end note

    component [ores.connections] as connections #F7E5FF
    note right of connections
    Server connection bookmarks: hierarchical
    folders, tags, AES-256-GCM credentials,
    SQLite persistence. Used by Qt and shell.
    end note

    component [ores.storage] as storage #F7E5FF
    note right of storage
    File storage: local paths, HTTP-based
    transfer, archive pack/unpack.
    end note
}

' ─────────────────────────────────────────────────────────────────────────────
' Domain Layer
' ─────────────────────────────────────────────────────────────────────────────
package "Domain Layer" #F2F2F2 {
    component [ores.refdata] as refdata #F7E5FF
    note right of refdata
    Currencies, countries, coding schemes, FPML
    product types. Temporal versioning, XML/CSV/JSON.
    refdata.v1.>
    end note

    component [ores.iam] as iam #F7E5FF
    note right of iam
    Account lifecycle, scrypt login, RBAC, session
    tracking with geolocation, bootstrap mode.
    iam.v1.>
    end note

    component [ores.dq] as dq #F7E5FF
    note right of dq
    Data quality: provenance, validation metadata,
    change management, staging artefacts,
    publish-from-DQ pattern. dq.v1.>
    end note

    component [ores.fpml] as fpml #F7E5FF
    note right of fpml
    FpML processing for OTC derivative trade
    representations. Early development.
    end note

    component [ores.ore] as ore #F7E5FF
    note right of ore
    ORE XML import/export: converts between ORE
    Engine XML and internal domain types.
    end note

    component [ores.trading] as trading #F7E5FF
    note right of trading
    Trade booking/lifecycle: FSM-enforced status,
    ~30 activity types, cancel-rebook, temporal
    versioning. trading.v1.>
    end note

    component [ores.marketdata] as marketdata #F7E5FF
    note right of marketdata
    Market series, observations, fixings, import
    options. marketdata.v1.>
    end note

    component [ores.synthetic] as synthetic #F7E5FF
    note right of synthetic
    Synthetic market data and scenario generation
    for stress testing. synthetic.v1.>
    end note

    component [ores.scheduler] as scheduler #F7E5FF
    note right of scheduler
    Task scheduling for compute jobs.
    scheduler.v1.>
    end note

    component [ores.reporting] as reporting #F7E5FF
    note right of reporting
    Report execution and result persistence.
    reporting.v1.>
    end note

    component [ores.analytics] as analytics #F7E5FF
    note right of analytics
    Risk analytics: NPV, sensitivities, VaR/CVaR.
    analytics.v1.>
    end note

    component [ores.workflow] as workflow #F7E5FF
    note right of workflow
    Multi-step compute pipeline management.
    workflow.v1.>
    end note
}

' ─────────────────────────────────────────────────────────────────────────────
' Application Layer
' ─────────────────────────────────────────────────────────────────────────────
package "Application Layer" #F2F2F2 {
    component [ores.shell] as shell #F7E5FF
    note right of shell
    Interactive REPL via NATS: currency queries,
    account management, auto-login. Dev/ops tool.
    end note

    component [ores.cli] as cli #F7E5FF
    note right of cli
    CLI import/export of reference data (JSON/XML/CSV)
    directly against the database.
    end note

    component [ores.qt] as qt #F7E5FF
    note right of qt
    Qt 6 MDI desktop app: currencies, accounts,
    parties, trades via NATS. Composed of
    ores.qt.* feature modules.
    end note

    component [ores.http.core] as httpcore #F7E5FF
    note right of httpcore
    Concrete HTTP route handlers: IAM, assets,
    risk, storage, variability. Translates HTTP
    requests into NATS calls.
    end note

    component [ores.http.server] as httpserver #F7E5FF
    note right of httpserver
    HTTP server entrypoint: wires http.core routes
    and runs Boost.Asio event loop.
    end note

    component [ores.wt.service] as wt #F7E5FF
    note right of wt
    Wt C++ Web Toolkit frontend: account mgmt,
    currency/country views, feature flags.
    Alternative to Qt desktop.
    end note

    component [ores.compute.service] as compute #F7E5FF
    note right of compute
    ORE Engine compute wrapper: receives compute
    job requests via NATS, spawns ORE child
    processes, publishes results.
    end note

    component [ores.controller] as controller #F7E5FF
    note right of controller
    Orchestration controller: assembles compute
    pipelines, sequences stages, tracks run state.
    end note
}

