{
  "domain_entity": {
    "schema": "public",
    "product": "ores",
    "component": "analytics",
    "component_include": "analytics.api",
    "component_core": "analytics.core",
    "list_filter_column": "config_id",
    "entity_singular": "pricing_model_product",
    "entity_plural": "pricing_model_products",
    "entity_title": "Pricing Model Product",
    "has_tenant_id": true,
    "brief": "Maps a pricing engine type to a model and engine within a pricing model configuration.",
    "description": "Detail row within a pricing model configuration. Each row maps a pricing engine type\n(e.g. EuropeanSwaption, CMS) to a specific model (e.g. LGM, BlackBachelier) and\nnumerical engine (e.g. Grid, AMC). Product-specific parameters are stored in\npricing_model_product_parameters.",

    "primary_key": {
      "column": "id",
      "type": "uuid",
      "cpp_type": "boost::uuids::uuid",
      "description": "UUID uniquely identifying this product mapping.",
      "detail": "Surrogate key for the pricing model product."
    },

    "columns": [
      {
        "name": "pricing_model_config_id",
        "type": "uuid",
        "cpp_type": "boost::uuids::uuid",
        "nullable": false,
        "description": "Parent pricing model configuration.",
        "detail": "Soft FK to ores_analytics_pricing_model_configs_tbl.",
        "generator_expr": "ctx.generate_uuid()"
      },
      {
        "name": "pricing_engine_type_code",
        "type": "text",
        "cpp_type": "std::string",
        "nullable": false,
        "description": "Pricing engine type this mapping applies to.",
        "detail": "Soft FK to ores_analytics_pricing_engine_types_tbl. Examples: 'Swap', 'EuropeanSwaption', 'CMS'.",
        "generator_expr": "std::string(\"Swap\")"
      },
      {
        "name": "model",
        "type": "text",
        "cpp_type": "std::string",
        "nullable": false,
        "description": "Pricing model name.",
        "detail": "Examples: 'DiscountedCashflows', 'LGM', 'BlackBachelier', 'GarmanKohlhagen', 'CrossAssetModel'.",
        "generator_expr": "std::string(\"DiscountedCashflows\")"
      },
      {
        "name": "engine",
        "type": "text",
        "cpp_type": "std::string",
        "nullable": false,
        "description": "Numerical engine name.",
        "detail": "Examples: 'DiscountingSwapEngine', 'Grid', 'AMC', 'AnalyticEuropeanEngine'.",
        "generator_expr": "std::string(\"DiscountingSwapEngine\")"
      }
    ],

    "sql": {
      "tablename": "ores_analytics_pricing_model_products_tbl"
    },

    "repository": {
      "entity_singular_short": "product",
      "entity_plural_short": "products",
      "entity_singular_words": "pricing model product",
      "entity_plural_words": "pricing model products"
    },

    "cpp": {
      "includes": {
        "domain": ["<chrono>", "<string>", "<boost/uuid/uuid.hpp>"],
        "entity": ["<string>", "\"sqlgen/Timestamp.hpp\"", "\"sqlgen/PrimaryKey.hpp\""]
      },
      "iterator_var": "pmp"
    },

    "qt": {
      "domain_include": "ores.analytics.api/domain/pricing_model_product.hpp",
      "domain_class": "analytics::domain::pricing_model_product",
      "protocol_include": "ores.analytics.api/messaging/pricing_model_product_protocol.hpp",
      "collection_name": "products",
      "item_var": "product",
      "key_field": "pricing_engine_type_code",
      "key_widget": "pricingEngineTypeCodeCombo",
      "has_uuid_primary_key": true,

      "get_request_class": "analytics::messaging::get_pricing_model_products_request",
      "get_response_class": "analytics::messaging::get_pricing_model_products_response",
      "get_message_type": "get_pricing_model_products_request",
      "save_request_class": "analytics::messaging::save_pricing_model_product_request",
      "save_response_class": "analytics::messaging::save_pricing_model_product_response",
      "save_message_type": "save_pricing_model_product_request",
      "delete_request_class": "analytics::messaging::delete_pricing_model_product_request",
      "delete_response_class": "analytics::messaging::delete_pricing_model_product_response",
      "delete_message_type": "delete_pricing_model_product_request",
      "history_request_class": "analytics::messaging::get_pricing_model_product_history_request",
      "history_response_class": "analytics::messaging::get_pricing_model_product_history_response",
      "history_message_type": "get_pricing_model_product_history_request",

      "detail_fields": [
        {
          "field": "pricing_engine_type_code",
          "label": "Pricing Engine Type",
          "widget": "pricingEngineTypeCodeCombo",
          "type": "dynamic_combo",
          "is_key": true,
          "is_required": true,
          "combo_type": "analytics::domain::pricing_engine_type",
          "combo_include": "ores.analytics.api/domain/pricing_engine_type.hpp",
          "combo_display": "code",
          "combo_value": "code",
          "combo_is_uuid": false,
          "combo_is_optional": false,
          "combo_setter": "setPricingEngineTypes",
          "combo_setter_pascal": "PricingEngineTypes",
          "combo_items_member": "pricingEngineTypes"
        },
        {
          "field": "model",
          "label": "Model",
          "widget": "modelEdit",
          "type": "line_edit",
          "is_required": true,
          "placeholder": "Pricing model (e.g. DiscountedCashflows, LGM, BlackBachelier)"
        },
        {
          "field": "engine",
          "label": "Engine",
          "widget": "engineEdit",
          "type": "line_edit",
          "is_required": true,
          "placeholder": "Numerical engine (e.g. DiscountingSwapEngine, Grid, AMC)"
        }
      ],

      "columns": [
        {"enum_name": "PricingEngineTypeCode", "field": "pricing_engine_type_code", "header": "Engine Type", "is_string": true, "width": 200},
        {"enum_name": "Model", "field": "model", "header": "Model", "is_string": true, "width": 200},
        {"enum_name": "Engine", "field": "engine", "header": "Engine", "is_string": true, "width": 200},
        {"enum_name": "Version", "field": "version", "header": "Version", "is_int": true, "width": 70},
        {"enum_name": "ModifiedBy", "field": "modified_by", "header": "Modified By", "is_string": true, "width": 120},
        {"enum_name": "RecordedAt", "field": "recorded_at", "header": "Recorded At", "is_timestamp": true, "width": 150}
      ],

      "settings_group": "PricingModelProductListWindow",
      "window_title": "Pricing Model Products",
      "icon": "Table"
    }
  }
}
