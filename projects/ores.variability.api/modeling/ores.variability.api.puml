@startuml

title ores.variability.api Component

set namespaceSeparator ::

namespace ores #F2F2F2 {
    namespace variability #F2F2F2 {
        namespace domain #F2F2F2 {
            class system_setting <<struct>> {
                +version : int
                +tenant_id : string
                +name : string
                +value : string
                +data_type : string
                +description : string
                +modified_by : string
                +change_reason_code : string
                +change_commentary : string
                +performed_by : string
                +recorded_at : chrono::system_clock::time_point
            }
            class system_setting_definition <<struct>> {
                +name : string_view
                +data_type : string_view
                +default_value : string_view
                +description : string_view
            }
        }
        namespace eventing #F2F2F2 {
            class system_setting_changed_event <<struct>> {
                +timestamp : chrono::system_clock::time_point
                +setting_names : vector<string>
                +tenant_id : string
            }
        }
        namespace messaging #F2F2F2 {
            class list_settings_request <<struct>> {
            }
            class list_settings_response <<struct>> {
                +settings : vector<ores::variability::domain::system_setting>
            }
            class save_setting_request <<struct>> {
                +data : ores::variability::domain::system_setting
            }
            class save_setting_response <<struct>> {
                +success : bool
                +message : string
            }
            class delete_setting_request <<struct>> {
                +name : string
            }
            class delete_setting_response <<struct>> {
                +success : bool
                +error_message : string
            }
            class get_setting_history_request <<struct>> {
                +name : string
            }
            class get_setting_history_response <<struct>> {
                +success : bool
                +message : string
                +history : vector<ores::variability::domain::system_setting>
            }
        }
    }
}

