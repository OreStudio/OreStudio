#ifndef ORES_UTILITY_VERSION_VERSION_HPP
#define ORES_UTILITY_VERSION_VERSION_HPP

#include <string>
#include <cstdint>

#define ORES_VERSION_MAJOR @OreStudio_VERSION_MAJOR@
#define ORES_VERSION_MINOR @OreStudio_VERSION_MINOR@
#define ORES_VERSION_PATCH @OreStudio_VERSION_PATCH@
#define ORES_VERSION "@OreStudio_VERSION_MAJOR@.@OreStudio_VERSION_MINOR@.@OreStudio_VERSION_PATCH@"

namespace ores::utility::version {

/**
 * @brief Returns the build info string stamped at build time.
 *
 * Contains the git commit hash, dirty flag, and wall-clock timestamp for
 * local builds, or CI provider/number/commit/timestamp for CI builds.
 * Implemented in a generated .cpp so only that one TU recompiles per build.
 */
const char* build_info();

/**
 * @brief Formats a startup message with version and build info.
 */
std::string format_startup_message(const std::string& service_name);

/**
 * @brief Formats a startup message with version, protocol, and build info.
 */
std::string format_startup_message(const std::string& service_name,
    std::uint16_t protocol_major, std::uint16_t protocol_minor);

}

#endif
