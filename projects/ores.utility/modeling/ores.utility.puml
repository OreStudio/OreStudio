@startuml

title ores.utility Component

set namespaceSeparator ::

namespace ores #F2F2F2 {
    namespace utility #F2F2F2 {
        namespace concurrency #F2F2F2 {
            class retry_strategy {
                -count_ : int
            }
        }
        namespace converter #F2F2F2 {
            class base32_converter {
            }
            class base64_converter {
            }
        }
        namespace faker #F2F2F2 {
            class datetime {
                +hour : int year, int month, int day, int
            }
            class internet {
            }
            class totp {
            }
        }
        namespace generation #F2F2F2 {
            class generation_context {
                -engine_ : shared_ptr<generation_engine>
                -env_ : shared_ptr<const generation_environment>
            }
            class generation_engine {
                -seed_ : uint64_t
                -engine_ : mt19937_64
            }
            class generation_environment {
                -parent_ : shared_ptr<const generation_environment>
                -entries_ : entries
            }
            class generation_keys <<struct>> {
            }
            class tree_node <<struct>> {
                +index : size_t
                +depth : size_t
                +parent_index : optional<size_t>
            }
        }
        namespace program_options #F2F2F2 {
            class common_options <<struct>> {
                +verbose : bool
            }
            class common_configuration {
            }
            class environment_mapper_factory {
            }
        }
        namespace serialization #F2F2F2 {
            enum error_code {
                none
                version_mismatch
                crc_validation_failed
                invalid_message_type
                handshake_timeout
                handshake_failed
                payload_too_large
                network_error
                handler_error
                database_error
                authentication_failed
                authorization_failed
                invalid_request
                bootstrap_mode_only
                bootstrap_mode_forbidden
                weak_password
                not_localhost
                database_unavailable
                decompression_failed
                unsupported_compression
                compression_failed
                signup_disabled
                username_taken
                email_taken
                signup_requires_authorization
                payload_incomplete
                limit_exceeded
                last_value
            }
            class reader {
                +max_count : uint32_t
            }
            class writer {
            }
        }
        namespace string #F2F2F2 {
            class converter {
            }
        }
        namespace uuid #F2F2F2 {
            class tenant_id {
                -uuid_ : boost::uuids::uuid
            }
            class uuid_v7_generator {
                -random_engine : mt19937_64
            }
        }
    }
}

