    "primary_key": {
      "column": "id",
      "type": "text",
      "cpp_type": "std::string",
      "description": "Unique index identifier.",
      "detail": "Examples: 'EUR-EURIBOR', 'USD-LIBOR'.",
      "generator_expr": "std::string(\"EUR-EURIBOR\")"
    },

