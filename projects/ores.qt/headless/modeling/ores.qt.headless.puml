@startuml

title ores.qt.headless Component

package "ores.qt.headless" {
  [OrgDocRenderer]
  [TestScenarioResultsWriter]
  [EnvironmentMetadata]
  [HierarchyModelBuilder]
  [RepoFileFinder]
  [FontUtils]
  [parse_trade_instrument]
  [IInstrumentFormPopulator]
}

[ores.qt.api] --> [ores.qt.headless] : links (PUBLIC)
[ores.qt.headless.tests] --> [ores.qt.headless] : links directly\n(no QApplication/display needed)
[OrgDocRenderer] --> [ores.orgmode] : renders parsed docs
[parse_trade_instrument] --> [ores.trading.api] : domain types
[TestScenarioResultsWriter] --> [EnvironmentMetadata]

@enduml
