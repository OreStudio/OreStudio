{
    "domain_entity": {
        "schema": "public",
        "product": "ores",
        "component": "trading",
        "component_include": "trading.api",
        "component_core": "trading.core",
        "entity_singular": "vanilla_swap_instrument",
        "entity_plural": "vanilla_swap_instruments",
        "entity_title": "Vanilla Swap Instrument",
        "has_tenant_id": true,
        "has_workspace_id": true,
        "has_batch_read": true,
        "generator_facet_name": "generators",
        "brief": "Vanilla interest rate swap or cross-currency swap instrument.",
        "description": "Represents a plain vanilla interest rate swap or cross-currency swap\ninstrument linking two legs via the swap_legs table.",
        "primary_key": {
            "column": "instrument_id",
            "type": "uuid",
            "cpp_type": "boost::uuids::uuid",
            "description": "UUID uniquely identifying this vanilla swap instrument.",
            "detail": "Surrogate key for the instrument record.",
            "uuid_check_fn": "ores_utility_nil_uuid_fn()"
        },
        "columns": [
            {
                "name": "trade_type_code",
                "type": "text",
                "cpp_type": "std::string",
                "nullable": false,
                "description": "Trade type code (soft FK to ores_trading_trade_types_tbl).",
                "generator_expr": "std::string(\"Swap\")"
            },
            {
                "name": "party_id",
                "type": "uuid",
                "cpp_type": "boost::uuids::uuid",
                "nullable": false,
                "description": "Party that owns this instrument.",
                "detail": "Set from session variable app.current_party_id."
            },
            {
                "name": "trade_id",
                "type": "uuid",
                "cpp_type": "std::optional<boost::uuids::uuid>",
                "nullable": true,
                "description": "Optional soft FK to the parent trade.",
                "detail": "Links instrument to a trade if applicable."
            },
            {
                "name": "start_date",
                "type": "date",
                "cpp_type": "std::string",
                "nullable": false,
                "description": "Swap effective/start date.",
                "detail": "ISO 8601 date string (YYYY-MM-DD).",
                "generator_expr": "std::string(\"2024-01-15\")"
            },
            {
                "name": "maturity_date",
                "type": "date",
                "cpp_type": "std::string",
                "nullable": false,
                "description": "Swap maturity/termination date.",
                "detail": "Must be after start_date.",
                "generator_expr": "std::string(\"2029-01-15\")"
            },
            {
                "name": "settlement_lag",
                "type": "integer",
                "cpp_type": "std::optional<int>",
                "nullable": true,
                "description": "Optional settlement lag in business days.",
                "detail": "Number of business days between execution and effective date."
            },
            {
                "name": "netting_set_id",
                "type": "text",
                "cpp_type": "std::string",
                "nullable": true,
                "description": "Optional netting set identifier.",
                "detail": "Groups instruments for netting purposes."
            },
            {
                "name": "description",
                "type": "text",
                "cpp_type": "std::string",
                "nullable": true,
                "description": "Optional free-text description.",
                "detail": "Human-readable notes about this instrument."
            }
        ],
        "sql": {
            "tablename": "ores_trading_vanilla_swap_instruments_tbl",
            "security_definer": true,
            "party_id_from_session": true,
            "extra_checks": [
                "\"maturity_date\" > \"start_date\"",
                "\"settlement_lag\" is null or \"settlement_lag\" >= 0"
            ]
        },
        "validations": [
            {
                "column": "trade_type_code",
                "validation_function": "ores_trading_validate_trade_type_fn"
            }
        ],
        "indexes": [
            {
                "name": "party",
                "columns": "tenant_id, party_id",
                "current_only": true
            },
            {
                "unique": true,
                "name": "trade_id",
                "columns": "tenant_id, trade_id",
                "current_only": true,
                "where_extra": "trade_id is not null"
            }
        ],
        "repository": {
            "entity_singular_short": "vanilla_swap_instrument",
            "entity_plural_short": "vanilla_swap_instruments",
            "entity_singular_words": "vanilla swap instrument",
            "entity_plural_words": "vanilla swap instruments"
        },
        "cpp": {
            "includes": {
                "domain": [
                    "<chrono>",
                    "<optional>",
                    "<string>",
                    "<boost/uuid/uuid.hpp>"
                ]
            },
            "iterator_var": "vs"
        }
    }
}
