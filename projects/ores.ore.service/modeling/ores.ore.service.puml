@startuml

title ores.ore.service Component

set namespaceSeparator ::

namespace ores #F2F2F2 {
    namespace ore #F2F2F2 {
        namespace service #F2F2F2 {

            namespace app #F2F2F2 {
                class application {
                    + run(io_ctx: io_context&, cfg: options): awaitable<void>
                    - make_context(db_opts: database_options): context
                }
            }

            namespace messaging #F2F2F2 {
                class ore_import_handler {
                    + ore_import(msg: message): void
                }
                class registrar {
                    + {static} register_handlers(nats, ctx, signer, outbound_nats, http_base_url, work_dir): vector<subscription>
                }
            }

            namespace service #F2F2F2 {
                class ore_import_workflow {
                    + execute(ctx, nats): bool
                    + compensate(ctx, nats): void
                    + failure_reason(): string const&
                    + result(): ore_import_response const&
                }
            }

            namespace config #F2F2F2 {
                class options {
                    + logging: optional<logging_options>
                    + nats: nats_options
                    + database: database_options
                    + http_base_url: string
                    + work_dir: string
                }
                class parser {
                    + parse(args, info, err): optional<options>
                }
            }

            app::application --> messaging::registrar : uses
            app::application --> config::options : configured by
            messaging::registrar --> messaging::ore_import_handler : registers
            messaging::ore_import_handler --> service::ore_import_workflow : executes
        }
    }
}

@enduml
