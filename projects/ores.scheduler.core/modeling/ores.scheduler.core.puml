@startuml

title ores.scheduler.core Component

set namespaceSeparator ::

namespace ores #F2F2F2 {
    namespace scheduler #F2F2F2 {
        namespace builder #F2F2F2 {
            class job_definition_builder {
                -name_ : string
                -description_ : string
                -command_ : string
                -error_ : string
                -tenant_id_ : optional<boost::uuids::uuid>
                -party_id_ : optional<boost::uuids::uuid>
                -modified_by_ : string
            }
        }
        namespace messaging #F2F2F2 {
            class job_instance_handler {
                -nats_ : ores::nats::service::client&
                -ctx_ : ores::database::context
                -verifier_ : optional<ores::security::jwt::jwt_authenticator>
            }
            class registrar {
                +verifier : optional<ores::security::jwt::jwt_authenticator>
            }
            class scheduler_status_handler {
                -nats_ : ores::nats::service::client&
                -ctx_ : ores::database::context
                -verifier_ : optional<ores::security::jwt::jwt_authenticator>
            }
        }
        namespace repository #F2F2F2 {
            class job_definition_entity <<struct>> {
                +schema : constexpr static const char*
                +tablename : constexpr static const char*
                +id : sqlgen::PrimaryKey<string>
                +tenant_id : optional<string>
                +version : int
                +party_id : optional<string>
                +job_name : string
                +description : optional<string>
                +command : string
                +schedule_expression : string
                +action_type : string
                +is_active : int
                +modified_by : string
                +performed_by : string
                +change_reason_code : string
                +change_commentary : string
                +valid_from : optional<db_timestamp>
                +valid_to : optional<db_timestamp>
            }
            class job_definition_mapper {
            }
            class job_definition_repository {
            }
            class job_instance_entity <<struct>> {
                +id : optional<string>
                +tenant_id : optional<string>
                +party_id : optional<string>
                +job_definition_id : optional<string>
                +action_type : optional<string>
                +status : optional<string>
                +triggered_at : optional<string>
                +started_at : optional<string>
                +completed_at : optional<string>
                +duration_ms : optional<string>
                +error_message : optional<string>
            }
            class job_instance_mapper {
            }
            class job_instance_repository {
                +error : domain::job_status status, const string&
                +limit : const boost::uuids::uuid& job_definition_id, size_t
            }
        }
        namespace service #F2F2F2 {
            class action_context <<struct>> {
                +job : const domain::job_definition&
                +db_ctx : database::context
                +inst_id : int64_t
            }
            class action_handler {
            }
            class cron_scheduler {
                +limit : size_t
                -ctx_ : context
                -repo_ : repository::job_definition_repository
                -inst_repo_ : repository::job_instance_repository
            }
            class job_definition_service {
                -ctx_ : context
                -repo_ : repository::job_definition_repository
            }
            class mq_action_handler {
            }
            class nats_publish_action_handler {
                -nats_ : ores::nats::service::client&
            }
            class scheduler_loop {
                -nats_ : ores::nats::service::client&
                -system_ctx_ : database::context
                -handlers_ : vector<unique_ptr<action_handler>>
                -jobs_ : vector<domain::job_definition>
                -last_run_ : map<boost::uuids::uuid, chrono::system_clock::time_point>
            }
            class sql_action_handler {
            }
        }
    }
}
namespace rfl #F2F2F2 {
    namespace ores #F2F2F2 {
        namespace scheduler #F2F2F2 {
            namespace messaging #F2F2F2 {
                class job_definition_handler {
                    -nats_ : ores::nats::service::client&
                    -ctx_ : ores::database::context
                    -verifier_ : optional<ores::security::jwt::jwt_authenticator>
                }
            }
        }
    }
}

