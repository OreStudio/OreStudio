@startuml

title ores.cli Component

set namespaceSeparator ::

namespace ores #F2F2F2 {
    namespace cli #F2F2F2 {
        namespace app #F2F2F2 {
            class application {
                -context_ : database::context
                -output_stream_ : ostream&
            }
            class host {
            }
        }
        namespace config #F2F2F2 {
            class add_account_options <<struct>> {
                +username : string
                +email : string
                +password : string
                +modified_by : string
                +admin : optional<bool>
            }
            class add_business_day_convention_type_options <<struct>> {
                +code : string
                +modified_by : string
                +description : optional<string>
            }
            class add_change_reason_category_options <<struct>> {
                +code : string
                +description : string
                +modified_by : string
                +change_commentary : optional<string>
            }
            class add_change_reason_options <<struct>> {
                +code : string
                +description : string
                +category_code : string
                +applies_to_amend : optional<bool>
                +applies_to_delete : optional<bool>
                +requires_commentary : optional<bool>
                +display_order : optional<int>
                +modified_by : string
                +change_commentary : optional<string>
            }
            class add_compute_app_options <<struct>> {
                +name : string
                +modified_by : string
                +description : optional<string>
            }
            class add_compute_app_version_options <<struct>> {
                +app_id : string
                +wrapper_version : string
                +engine_version : string
                +platform_packages : vector<platform_package>
                +modified_by : string
                +min_ram_mb : optional<int>
            }
            class add_compute_batch_options <<struct>> {
                +external_ref : string
                +modified_by : string
                +status : optional<string>
            }
            class add_compute_host_options <<struct>> {
                +external_id : string
                +modified_by : string
                +location : optional<string>
                +cpu_count : optional<int>
                +ram_mb : optional<int>
                +gpu_type : optional<string>
            }
            class add_compute_workunit_options <<struct>> {
                +batch_id : string
                +app_version_id : string
                +input_uri : string
                +config_uri : string
                +modified_by : string
                +priority : optional<int>
                +target_redundancy : optional<int>
            }
            class add_country_options <<struct>> {
                +alpha2_code : string
                +alpha3_code : string
                +name : string
                +numeric_code : optional<string>
                +official_name : optional<string>
                +modified_by : string
                +change_reason_code : optional<string>
                +change_commentary : optional<string>
            }
            class add_currency_options <<struct>> {
                +iso_code : string
                +name : string
                +modified_by : string
                +numeric_code : optional<string>
                +symbol : optional<string>
                +fraction_symbol : optional<string>
                +fractions_per_unit : optional<int>
                +rounding_type : optional<string>
                +rounding_precision : optional<int>
                +format : optional<string>
                +monetary_nature : optional<string>
                +market_tier : optional<string>
            }
            class add_day_count_fraction_type_options <<struct>> {
                +code : string
                +modified_by : string
                +description : optional<string>
            }
            class add_floating_index_type_options <<struct>> {
                +code : string
                +modified_by : string
                +description : optional<string>
            }
            class add_leg_type_options <<struct>> {
                +code : string
                +modified_by : string
                +description : optional<string>
            }
            class add_login_info_options <<struct>> {
                +account_id : string
                +locked : optional<bool>
                +failed_logins : optional<int>
            }
            class add_payment_frequency_type_options <<struct>> {
                +code : string
                +modified_by : string
                +description : optional<string>
            }
            class add_permission_options <<struct>> {
                +code : string
                +description : optional<string>
            }
            class add_role_options <<struct>> {
                +name : string
                +description : string
                +modified_by : string
                +change_reason_code : optional<string>
                +change_commentary : optional<string>
                +permission_codes : vector<string>
            }
            class add_system_setting_options <<struct>> {
                +setting_name : string
                +modified_by : string
                +value : optional<string>
                +data_type : optional<string>
                +description : optional<string>
            }
            class delete_options <<struct>> {
                +target_entity : entity
                +key : string
            }
            enum domain {
            }
            enum entity {
                currencies
                countries
                conventions
                accounts
                roles
                permissions
                login_info
                change_reasons
                change_reason_categories
                feature_flags
                system_settings
                compute_hosts
                compute_apps
                compute_app_versions
                compute_batches
                compute_workunits
                compute_results
                day_count_fraction_types
                business_day_convention_types
                floating_index_types
                payment_frequency_types
                leg_types
            }
            class export_options <<struct>> {
            }
            enum format {
                json
                xml
                csv
                table
            }
            class import_options <<struct>> {
                +target_entity : entity
                +targets : vector<filesystem::path>
            }
            class list_options <<struct>> {
                +target_entity : entity
                +target_format : format
                +as_of : string
                +key : string
                +all_versions : bool
            }
            enum operation {
                import_data
                export_data
                list_entity
                delete_entity
                add_entity
            }
            class options <<struct>> {
                +logging : optional<ores::logging::logging_options>
                +importing : optional<import_options>
                +exporting : optional<export_options>
                +deleting : optional<delete_options>
                +listing : optional<list_options>
                +adding : optional<add_options>
                +ore_roundtrip : optional<ore_roundtrip_options>
                +database : ores::database::database_options
            }
            class ore_roundtrip_options <<struct>> {
                +input_dir : filesystem::path
                +output_dir : filesystem::path
            }
            class parser {
            }
            namespace parser_helpers #F2F2F2 {
                class simple_entity_config <<struct>> {
                    +name : string_view
                    +description : string_view
                    +entity_value : entity
                    +list_description : string_view
                    +delete_description : string_view
                }
            }
        }
    }
}

