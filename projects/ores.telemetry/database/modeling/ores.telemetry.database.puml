@startuml

title ores.telemetry.database Component

set namespaceSeparator ::

namespace ores #F2F2F2 {
    namespace telemetry #F2F2F2 {
        namespace database #F2F2F2 {
            namespace repository #F2F2F2 {
                class telemetry_entity <<struct>> {
                    +schema : constexpr static const char*
                    +tablename : constexpr static const char*
                    +id : sqlgen::PrimaryKey<string>
                    +tenant_id : string
                    +timestamp : sqlgen::PrimaryKey<db_timestamp>
                    +source : string
                    +source_name : string
                    +session_id : optional<string>
                    +account_id : optional<string>
                    +level : string
                    +component : string
                    +message : string
                    +tag : string
                    +recorded_at : db_timestamp
                }
                class telemetry_stats_hourly_entity <<struct>> {
                    +schema : constexpr static const char*
                    +tablename : constexpr static const char*
                    +hour : string
                    +source : string
                    +source_name : string
                    +level : string
                    +log_count : int64_t
                    +unique_sessions : int64_t
                    +unique_accounts : int64_t
                }
                class telemetry_stats_daily_entity <<struct>> {
                    +schema : constexpr static const char*
                    +tablename : constexpr static const char*
                    +day : string
                    +source : string
                    +source_name : string
                    +component : string
                    +level : string
                    +log_count : int64_t
                    +unique_sessions : int64_t
                    +unique_accounts : int64_t
                }
                class nats_server_sample_entity <<struct>> {
                    +schema : constexpr static const char*
                    +tablename : constexpr static const char*
                    +sampled_at : sqlgen::PrimaryKey<db_timestamp>
                    +tenant_id : sqlgen::PrimaryKey<string>
                }
                class service_sample_entity <<struct>> {
                    +schema : constexpr static const char*
                    +tablename : constexpr static const char*
                    +sampled_at : sqlgen::PrimaryKey<db_timestamp>
                    +service_name : sqlgen::PrimaryKey<string>
                    +instance_id : sqlgen::PrimaryKey<string>
                    +version : string
                }
                class nats_stream_sample_entity <<struct>> {
                    +schema : constexpr static const char*
                    +tablename : constexpr static const char*
                    +sampled_at : sqlgen::PrimaryKey<db_timestamp>
                    +tenant_id : sqlgen::PrimaryKey<string>
                    +stream_name : sqlgen::PrimaryKey<string>
                }
                class telemetry_mapper {
                }
                class telemetry_repository {
                    +limit : uint32_t
                    +limit : uint32_t
                    +hours : uint32_t
                }
            }
        }
    }
}

