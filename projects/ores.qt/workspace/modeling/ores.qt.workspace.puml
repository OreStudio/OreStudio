@startuml

title ores.qt.workspace Component

set namespaceSeparator ::

namespace ores #F2F2F2 {
    namespace qt #F2F2F2 {
        class ClientWorkspaceModel {
            +parent : QObject*
            +role : int
            -clientManager_ : ClientManager*
            -workspaces_ : vector<workspace::domain::workspace>
            -watcher_ : QFutureWatcher<FetchResult>*
            -recencyTracker_ : WorkspaceKeyExtractor, WorkspaceTimestampExtractor>
            -pulseManager_ : RecencyPulseManager*
        }
        class WorkspaceController {
            +parent : QObject*
            -listWindow_ : WorkspaceMdiWindow*
            -listMdiSubWindow_ : DetachableMdiSubWindow*
        }
        class WorkspaceDetailDialog {
            -ui_ : Ui::WorkspaceDetailDialog*
            -clientManager_ : ClientManager*
            -username_ : string
            -workspace_ : workspace::domain::workspace
        }
        class WorkspaceMdiWindow {
            +parent : QWidget*
            -clientManager_ : ClientManager*
            -username_ : QString
            -toolbar_ : QToolBar*
            -tableView_ : QTableView*
            -model_ : ClientWorkspaceModel*
            -proxyModel_ : QSortFilterProxyModel*
            -paginationWidget_ : PaginationWidget*
            -reloadAction_ : QAction*
            -addAction_ : QAction*
            -editAction_ : QAction*
            -archiveAction_ : QAction*
            -deleteAction_ : QAction*
        }
        class WorkspacePlugin {
            -ctx_ : plugin_context
            -workspaceController_ : unique_ptr<WorkspaceController>
        }
    }
}

' --- manual: everything below this line is hand-authored; the script preserves it ---

