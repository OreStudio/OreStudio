assets --> nats
httpapi --> logging
connections --> security
storage --> platform

' ─────────────────────────────────────────────────────────────────────────────
' Dependencies — Domain to Foundation/Infrastructure
' ─────────────────────────────────────────────────────────────────────────────
refdata --> database
refdata --> nats
iam --> database
iam --> nats
iam --> geo
iam --> security
iam --> variability
dq --> database
dq --> nats
fpml --> logging
ore --> refdata
ore --> logging
trading --> database
trading --> nats
trading --> refdata
trading --> fpml
trading --> dq
marketdata --> database
marketdata --> nats
synthetic --> database
synthetic --> nats
scheduler --> database
scheduler --> nats
reporting --> database
reporting --> nats
analytics --> database
analytics --> nats
workflow --> database
workflow --> nats

' ─────────────────────────────────────────────────────────────────────────────
' Dependencies — Application to all layers
' ─────────────────────────────────────────────────────────────────────────────
shell --> nats
shell --> iam
shell --> refdata

cli --> database
cli --> refdata
cli --> ore

qt --> nats
qt --> iam
qt --> refdata
qt --> assets
qt --> connections
qt --> trading
