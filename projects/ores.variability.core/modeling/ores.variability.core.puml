@startuml

title ores.variability.core Component

set namespaceSeparator ::

namespace ores #F2F2F2 {
    namespace variability #F2F2F2 {
        namespace messaging #F2F2F2 {
            class registrar {
                +verifier : optional<ores::security::jwt::jwt_authenticator>
            }
            class system_setting_handler {
                -nats_ : ores::nats::service::client&
                -ctx_ : ores::database::context
                -verifier_ : optional<ores::security::jwt::jwt_authenticator>
            }
        }
        namespace repository #F2F2F2 {
            class system_setting_entity <<struct>> {
                +schema : constexpr static const char*
                +tablename : constexpr static const char*
                +name : sqlgen::PrimaryKey<string>
                +tenant_id : string
                +version : int
                +value : string
                +data_type : string
                +description : string
                +modified_by : string
                +performed_by : string
                +change_reason_code : string
                +change_commentary : string
                +valid_from : db_timestamp
                +valid_to : db_timestamp
            }
            class system_setting_mapper {
            }
            class system_settings_repository {
            }
        }
        namespace service #F2F2F2 {
            class system_settings_service {
                -cache_ : unordered_map<string, string>
                -ctx_ : database::context
                -tenant_id_ : string
                -repo_ : repository::system_settings_repository
            }
        }
    }
}

