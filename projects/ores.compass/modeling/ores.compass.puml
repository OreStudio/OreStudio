@startuml

title ores.compass Component

skinparam linetype ortho
left to right direction

package "Inputs" #E8F4FD {
    [.org-roam.db\n(EmacSQL, read-only)] as roam
    [Agile docs\ndoc/agile/versions/] as agile
    [Search query] as query
}

package "Compass CLI" #F2F2F2 {
    [compass.sh\n(venv bootstrap)] as wrapper
    [index\n(build FTS cache)] as index
    [search\n(FTS5 retrieval)] as search
    [where / status\n(Locate — planned)] as locate
    [add <type>\n(Scaffold — planned)] as scaffold
}

package "Backends" #FFF8E8 {
    [ores.codegen\ngenerate_doc.sh] as codegen
}

package "Outputs" #E8FDE8 {
    [.compass.db\n(FTS5 cache)] as cache
    [Results\n(pretty / line / json)] as results
    [New v2 .org docs\n(planned)] as newdocs
}

wrapper --> index
wrapper --> search
wrapper --> locate
wrapper --> scaffold

roam --> index
index --> cache
cache --> search
query --> search
search --> results

agile --> locate
locate --> results

scaffold --> codegen
codegen --> newdocs

' Local Variables:
' compile-command: "java -Djava.awt.headless=true -DPLANTUML_SECURITY_PROFILE=UNSECURE -DPLANTUML_LIMIT_SIZE=65535 -jar /usr/share/plantuml/plantuml.jar ores.compass.puml"
' End:
@enduml
