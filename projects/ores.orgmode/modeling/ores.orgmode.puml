@startuml

title ores.orgmode Component (planned — currently a codegen stub)

set namespaceSeparator ::

namespace ores #F2F2F2 {
    namespace orgmode #F2F2F2 {
        namespace domain #FEFECE {
            class document <<struct>> {
                +keywords : std::vector<keyword>
                +properties : std::map<std::string, std::string>
                +headings : std::vector<heading>
            }
            class heading <<struct>> {
                +level : unsigned int
                +title : std::string
                +todo_keyword : std::string
                +body : std::vector<block>
                +children : std::vector<heading>
            }
            class link <<struct>> {
                +target_id : std::string
                +text : std::string
            }
            document o-- heading
            heading o-- link
        }
        namespace parser #FEFECE {
            class parse <<function>> {
                +parse(path: std::filesystem::path) : domain::document
            }
            parse ..> domain::document : produces
        }
        namespace indexing #FEFECE {
            class resolver <<class>> {
                +resolve(link: domain::link) : resolved_target
            }
            resolver ..> domain::link : consumes
        }
    }
}

@enduml
