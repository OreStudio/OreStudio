@startuml

title ores.compute.wrapper Component

set namespaceSeparator ::

namespace ores #F2F2F2 {
    namespace compute #F2F2F2 {
        namespace wrapper #F2F2F2 {

            namespace net #F2F2F2 {
                class http_client {
                    + {static} download(url: string, dest: path): void
                    + {static} upload(url: string, src: path): void
                    - {static} parse_url(url: string): url_parts
                }
                class http_client::url_parts {
                    + host: string
                    + port: string
                    + path: string
                }
            }

            namespace app #F2F2F2 {
                class heartbeat_sender {
                    + start(): void
                    + stop(): void
                    - run(): void
                    - send_heartbeat(): void
                    - nats_: client&
                    - host_id_: string
                    - interval_: uint32_t
                    - stop_: atomic<bool>
                    - thread_: thread
                }
                class application {
                    + run(io_ctx: io_context&, cfg: options): awaitable<void>
                }
            }

            namespace config #F2F2F2 {
                class options {
                    + host_id: string
                    + tenant_id: string
                    + nats: nats_options
                    + work_dir: string
                    + heartbeat_interval_seconds: uint32_t
                    + http_base_url: string
                }
                class parser {
                    + {static} parse(argc: int, argv: char**): options
                }
            }

            app::application --> net::http_client : uses
            app::application --> app::heartbeat_sender : creates
            app::application --> config::options : configured by
            config::parser ..> config::options : creates
        }
    }
}

@enduml
