{
    "domain_entity": {
        "schema": "public",
        "product": "ores",
        "component": "trading",
        "component_include": "trading.api",
        "component_core": "trading.core",
        "entity_singular": "swaption_instrument",
        "entity_plural": "swaption_instruments",
        "entity_title": "Swaption Instrument",
        "has_tenant_id": true,
        "has_workspace_id": true,
        "has_batch_read": true,
        "generator_facet_name": "generators",
        "brief": "Swaption (option on an interest rate swap) instrument.",
        "description": "Represents a swaption \u2014 an option granting the right to enter into an\ninterest rate swap at a future date. Exercise type may be European,\nBermudan, or American.",
        "primary_key": {
            "column": "instrument_id",
            "type": "uuid",
            "cpp_type": "boost::uuids::uuid",
            "description": "UUID uniquely identifying this swaption instrument.",
            "detail": "Surrogate key for the instrument record.",
            "uuid_check_fn": "ores_utility_nil_uuid_fn()"
        },
        "columns": [
            {
                "name": "trade_type_code",
                "type": "text",
                "cpp_type": "std::string",
                "nullable": false,
                "description": "Trade type code (soft FK to ores_trading_trade_types_tbl).",
                "generator_expr": "std::string(\"EuropeanSwaption\")"
            },
            {
                "name": "party_id",
                "type": "uuid",
                "cpp_type": "boost::uuids::uuid",
                "nullable": false,
                "description": "Party that owns this instrument.",
                "detail": "Set from session variable app.current_party_id."
            },
            {
                "name": "trade_id",
                "type": "uuid",
                "cpp_type": "std::optional<boost::uuids::uuid>",
                "nullable": true,
                "description": "Optional soft FK to the parent trade.",
                "detail": "Links instrument to a trade if applicable."
            },
            {
                "name": "expiry_date",
                "type": "date",
                "cpp_type": "std::string",
                "nullable": false,
                "description": "Option expiry date.",
                "detail": "ISO 8601 date string (YYYY-MM-DD).",
                "generator_expr": "std::string(\"2025-06-15\")"
            },
            {
                "name": "exercise_type",
                "type": "text",
                "cpp_type": "std::string",
                "nullable": false,
                "description": "Exercise type: European, Bermudan, or American.",
                "detail": "Determines when the option may be exercised.",
                "generator_expr": "std::string(\"European\")"
            },
            {
                "name": "settlement_type",
                "type": "text",
                "cpp_type": "std::string",
                "nullable": false,
                "description": "Settlement type: Cash or Physical.",
                "detail": "Determines how the swaption is settled upon exercise.",
                "generator_expr": "std::string(\"Physical\")"
            },
            {
                "name": "long_short",
                "type": "text",
                "cpp_type": "std::string",
                "nullable": false,
                "description": "Position direction: Long or Short.",
                "detail": "Indicates whether the party holds or writes the option.",
                "generator_expr": "std::string(\"Long\")"
            },
            {
                "name": "start_date",
                "type": "date",
                "cpp_type": "std::string",
                "nullable": true,
                "description": "Optional underlying swap start date.",
                "detail": "ISO 8601 date string (YYYY-MM-DD). Null if not yet determined."
            },
            {
                "name": "maturity_date",
                "type": "date",
                "cpp_type": "std::string",
                "nullable": true,
                "description": "Optional underlying swap maturity date.",
                "detail": "ISO 8601 date string (YYYY-MM-DD). Null if not yet determined."
            },
            {
                "name": "description",
                "type": "text",
                "cpp_type": "std::string",
                "nullable": true,
                "description": "Optional free-text description.",
                "detail": "Human-readable notes about this instrument."
            }
        ],
        "sql": {
            "tablename": "ores_trading_swaption_instruments_tbl",
            "security_definer": true,
            "party_id_from_session": true,
            "extra_checks": [
                "\"exercise_type\" in ('European', 'Bermudan', 'American')",
                "\"settlement_type\" in ('Cash', 'Physical')",
                "\"long_short\" in ('Long', 'Short')",
                "\"maturity_date\" is null or \"start_date\" is null or \"maturity_date\" > \"start_date\""
            ]
        },
        "validations": [
            {
                "column": "trade_type_code",
                "validation_function": "ores_trading_validate_trade_type_fn"
            }
        ],
        "indexes": [
            {
                "name": "party",
                "columns": "tenant_id, party_id",
                "current_only": true
            },
            {
                "unique": true,
                "name": "trade_id",
                "columns": "tenant_id, trade_id",
                "current_only": true,
                "where_extra": "trade_id is not null"
            }
        ],
        "repository": {
            "entity_singular_short": "swaption_instrument",
            "entity_plural_short": "swaption_instruments",
            "entity_singular_words": "swaption instrument",
            "entity_plural_words": "swaption instruments"
        },
        "cpp": {
            "includes": {
                "domain": [
                    "<chrono>",
                    "<optional>",
                    "<string>",
                    "<boost/uuid/uuid.hpp>"
                ]
            },
            "iterator_var": "sw"
        }
    }
}
