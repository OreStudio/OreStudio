@startuml
!pragma layout smetana

title Task lifecycle

skinparam state {
    BackgroundColor #2A2A2E
    BorderColor #58A6FF
    FontColor #E3E3E6
    AttributeFontColor #A1A1AA
    ArrowColor #8AB4F8
    ArrowFontColor #E3E3E6
    StartColor #58A6FF
    EndColor #58A6FF
}
skinparam BackgroundColor transparent
skinparam DefaultFontColor #E3E3E6

state DISCOVERED
state BACKLOG
state STARTED
state BLOCKED
state DONE      <<end>>
state ABANDONED <<end>>

[*]         --> DISCOVERED : found while\nexecuting another task
DISCOVERED  --> BACKLOG    : triage
BACKLOG     --> STARTED    : claim
STARTED     --> BLOCKED    : hit a wait
BLOCKED     --> STARTED    : wait cleared
STARTED     --> DONE       : PR merged
DISCOVERED  --> ABANDONED  : give up
BACKLOG     --> ABANDONED  : give up
STARTED     --> ABANDONED  : give up
BLOCKED     --> ABANDONED  : give up

note right of BLOCKED
  Reason in =#+blocked_on=
  (review / ci / local_build / external);
  timestamp in =#+blocked_since=.
end note

note right of DONE
  Org auto-stamps =CLOSED:=
  on the Status headline.
end note

note right of ABANDONED
  Reason recorded in
  =* Notes= section.
end note

@enduml
