@startuml

title ores.testing Component

set namespaceSeparator ::

namespace ores #F2F2F2 {
    namespace testing #F2F2F2 {
        class database_helper {
            -context_ : database::context
        }
        class database_lifecycle_listener {
            -test_tenant_id_ : string
        }
        class logging_listener {
            -lifecycle_manager_ : shared_ptr<telemetry::log::lifecycle_manager>
        }
        class project_root {
        }
        class scoped_database_helper {
            -helper_ : database_helper
        }
        class test_database_manager {
        }
        class test_timeout_listener {
            -test_start_time_ : chrono::steady_clock::time_point
            -current_test_name_ : string
            -watchdog_thread_ : thread
        }
    }
}

