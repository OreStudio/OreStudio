@startuml
!pragma layout smetana

skinparam defaultFontSize 13
skinparam arrowThickness 2
skinparam arrowColor #555555
skinparam rectangleBorderThickness 2
skinparam rectangleFontSize 13

title ORE Studio — Four-Layer Architecture

rectangle "**Application Layer**\n\nQt desktop · CLI · HTTP servers\nWt web frontend · Compute engine\nOrchestration controller" as APP #D6EAF8
rectangle "**Domain Layer**\n\nIAM · Reference data · Trading\nMarket data · Analytics · Reporting\nWorkflow · Scheduler · DQ · ORE · FpML" as DOM #D5F5E3
rectangle "**Infrastructure Layer**\n\nores.nats (messaging backbone)\nService runner · Test isolation\nEvent bus · Connection bookmarks" as INFRA #FEF9E7
rectangle "**Foundation Layer**\n\nUtility · Platform · Logging\nTelemetry · Database · Security\nVariability · Geo · SQL · Codegen" as FOUND #F5EEF8

APP -[hidden]-> DOM
DOM -[hidden]-> INFRA
INFRA -[hidden]-> FOUND

APP ..> DOM : depends on
DOM ..> INFRA : depends on
INFRA ..> FOUND : depends on

' Local Variables:
' compile-command: "java -Djava.awt.headless=true -DPLANTUML_SECURITY_PROFILE=UNSECURE -DPLANTUML_LIMIT_SIZE=65535 -jar /usr/share/plantuml/plantuml.jar architecture_layers.puml"
' End:
@enduml
