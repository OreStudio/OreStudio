@startuml

title ores.history Component

set namespaceSeparator ::

namespace ores #F2F2F2 {
    namespace diff #F2F2F2 {
        namespace domain #FEFECE {
            class field_value <<struct>>
            class diff_result <<struct>>
        }
    }
    namespace history #F2F2F2 {
        namespace messaging #FEFECE {
            class get_entity_history_request <<struct>> {
                +entity_type : std::string
                +entity_id : std::string
            }
            class get_entity_history_response <<struct>> {
                +versions : std::vector<entity_history_version>
                +success : bool
                +message : std::string
            }
            class entity_history_version <<struct>> {
                +version : int
                +modified_by : std::string
                +recorded_at : time_point
                +fields : std::vector<field_value>
                +changes : diff_result
            }
            get_entity_history_response o-- entity_history_version
            entity_history_version ..> ores::diff::domain::field_value : renders
            entity_history_version ..> ores::diff::domain::diff_result : diffs
        }
        namespace service #FEFECE {
            class dispatch_registry <<class>> {
                +register_history_provider(entity_type, provider) : void
                +has_provider(entity_type) : bool
                +provider_count() : size_t
                +dispatch(request) : get_entity_history_response
            }
            dispatch_registry ..> messaging::get_entity_history_request : consumes
            dispatch_registry ..> messaging::get_entity_history_response : produces
        }
    }
}

@enduml
