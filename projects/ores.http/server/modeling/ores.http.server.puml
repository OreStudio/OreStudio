@startuml

title ores.http.server Component

set namespaceSeparator ::

namespace ores #F2F2F2 {
    namespace http_server #F2F2F2 {
        namespace app #F2F2F2 {
            class application {
            }
            class host {
            }
        }
        namespace config #F2F2F2 {
            class options <<struct>> {
                +logging : optional<ores::logging::logging_options>
                +server : http::net::http_server_options
                +database : ores::database::database_options
                +nats : ores::nats::config::nats_options
                +http_base_url : string
            }
            class parser {
            }
            class parser_exception {
                -message_ : string
            }
        }
        namespace messaging #F2F2F2 {
            class http_info_handler {
                -nats_ : ores::nats::service::client&
                -verifier_ : ores::security::jwt::jwt_authenticator
                -base_url_ : string
            }
            class registrar {
            }
        }
    }
}

