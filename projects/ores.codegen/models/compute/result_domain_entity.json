{
  "domain_entity": {
    "schema": "public",
    "product": "ores",
    "component": "compute",
    "entity_singular": "result",
    "entity_plural": "results",
    "entity_title": "Result",
    "has_tenant_id": true,
    "brief": "A specific execution instance of a workunit assigned to a host.",
    "description": "Bridges the workunit definition and the actual execution on a grid node.\nTracks PGMQ lease state, server-side lifecycle (Inactive/Unsent/InProgress/Done),\nand the location of output data. The BOINC equivalent of 'result'.",

    "primary_key": {
      "column": "id",
      "type": "uuid",
      "cpp_type": "boost::uuids::uuid",
      "description": "UUID primary key for the result."
    },

    "columns": [
      {
        "name": "workunit_id",
        "type": "uuid",
        "cpp_type": "boost::uuids::uuid",
        "nullable": false,
        "description": "FK reference to ores_compute_workunits_tbl."
      },
      {
        "name": "host_id",
        "type": "uuid",
        "cpp_type": "boost::uuids::uuid",
        "nullable": true,
        "description": "FK reference to ores_compute_hosts_tbl; NULL until the result is dispatched."
      },
      {
        "name": "pgmq_msg_id",
        "type": "bigint",
        "cpp_type": "std::int64_t",
        "nullable": true,
        "description": "PGMQ lease pointer; NULL when not actively queued."
      },
      {
        "name": "server_state",
        "type": "integer",
        "cpp_type": "int",
        "nullable": false,
        "default": "1",
        "description": "State machine: 1=Inactive, 2=Unsent, 4=InProgress, 5=Done."
      },
      {
        "name": "outcome",
        "type": "integer",
        "cpp_type": "int",
        "nullable": true,
        "description": "Result outcome code: 1=Success, 3=ClientError, 4=NoReply."
      },
      {
        "name": "output_uri",
        "type": "text",
        "cpp_type": "std::string",
        "nullable": true,
        "description": "URI where the wrapper uploaded the zipped output; NULL until completed."
      },
      {
        "name": "received_at",
        "type": "timestamp with time zone",
        "cpp_type": "std::chrono::system_clock::time_point",
        "nullable": true,
        "description": "Timestamp when the output was received by the server pool."
      }
    ],

    "indexes": [
      {
        "name": "workunit_id",
        "columns": "tenant_id, workunit_id",
        "unique": false,
        "current_only": true
      },
      {
        "name": "host_id",
        "columns": "tenant_id, host_id",
        "unique": false,
        "current_only": true
      },
      {
        "name": "server_state",
        "columns": "tenant_id, server_state",
        "unique": false,
        "current_only": true
      }
    ],

    "sql": {
      "tablename": "ores_compute_results_tbl"
    },

    "repository": {
      "entity_singular_short": "result",
      "entity_plural_short": "results",
      "entity_singular_words": "compute result",
      "entity_plural_words": "compute results"
    },

    "cpp": {
      "includes": {
        "domain": ["<string>", "<cstdint>", "<chrono>", "<boost/uuid/uuid.hpp>"]
      },
      "iterator_var": "r"
    }
  }
}
