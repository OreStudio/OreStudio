@startuml

title ores.database Component

set namespaceSeparator ::

namespace ores #F2F2F2 {
    namespace database #F2F2F2 {
        class database_configuration {
        }
        class context {
            -connection_pool_ : connection_pool_type
            -credentials_ : sqlgen::postgres::Credentials
            -service_account_ : string
            -roles_ : vector<string>
        }
        class database_options <<struct>> {
            +user : string
            +password : rfl::Skip<string>
            +host : string
            +database : string
            +port : int
            +tenant : string
        }
        class db_connection_exception {
        }
        class context_factory {
        }
        class health_monitor {
            -options_ : database_options
            -poll_interval_ : chrono::seconds
            -mutex_ : mutable mutex
            -last_error_ : string
            -status_callback_ : status_change_callback
            -stop_signal_ : boost::asio::cancellation_signal
        }
        namespace domain #F2F2F2 {
            class database_info <<struct>> {
                +id : boost::uuids::uuid
                +schema_version : string
                +build_environment : string
                +git_commit : string
                +git_date : string
                +created_at : chrono::system_clock::time_point
            }
        }
        namespace repository #F2F2F2 {
            class database_info_entity <<struct>> {
                +schema : constexpr static const char*
                +tablename : constexpr static const char*
                +id : sqlgen::PrimaryKey<string>
                +schema_version : string
                +build_environment : string
                +git_commit : string
                +git_date : string
                +created_at : optional<db_timestamp>
            }
            class database_info_mapper {
            }
            class database_info_repository {
            }
        }
        namespace service #F2F2F2 {
            class party_context {
                +actor : const string&
            }
            class postgres_listener_service {
                -ctx_ : context
                -notification_callback_ : notification_callback_t
                -mutex_ : mutable mutex
                -connection_ : optional<rfl::Ref<sqlgen::postgres::Connection>>
                -subscribed_channels_ : vector<string>
                -listener_thread_ : thread
                -running_ : atomic<bool>
                -ready_cv_ : condition_variable
            }
            class tenant_context {
            }
        }
    }
}

