@startuml

title ores.history Component

set namespaceSeparator ::

namespace ores #F2F2F2 {
    namespace diff #F2F2F2 {
        namespace domain #FEFECE {
            class field_value <<struct>>
            class diff_result <<struct>>
        }
    }
    namespace history #F2F2F2 {
        namespace messaging #FEFECE {
            class get_entity_history_request <<struct>> {
                +entity_type : std::string
                +entity_id : std::string
            }
            class get_entity_history_response <<struct>> {
                +versions : std::vector<entity_history_version>
                +success : bool
                +message : std::string
            }
            class entity_history_version <<struct>> {
                +version : int
                +modified_by : std::string
                +recorded_at : time_point
                +fields : std::vector<field_value>
                +changes : diff_result
            }
            get_entity_history_response o-- entity_history_version
            entity_history_version ..> ores::diff::domain::field_value : renders
            entity_history_version ..> ores::diff::domain::diff_result : diffs

            class history_handler <<class>> {
                +history(msg) : void
            }
            history_handler --> service::dispatch_registry : dispatches via
            history_handler ..> get_entity_history_request : decodes
            history_handler ..> get_entity_history_response : replies with
            history_handler ..> ores::database::context : resolves via make_request_context()
        }
        namespace service #FEFECE {
            class dispatch_registry <<class>> {
                +register_history_provider(entity_type, provider) : void
                +has_provider(entity_type) : bool
                +provider_count() : size_t
                +dispatch(request, ctx) : get_entity_history_response
            }
            dispatch_registry ..> messaging::get_entity_history_request : consumes
            dispatch_registry ..> messaging::get_entity_history_response : produces

            class build_entity_history_versions <<function>> {
                (versions, render) -> vector<entity_history_version>
            }
            build_entity_history_versions ..> messaging::entity_history_version : builds
            build_entity_history_versions ..> ores::diff::domain::diff_result : via ores.diff::engine::compute
        }
    }
}

note right of ores::history::messaging::history_handler
  register_history_handlers(nats, registry, queue_group, ctx, verifier)
  subscribes the single history.v1.get subject to a
  history_handler backed by the caller-owned registry.
  Each request is resolved into a scoped database::context
  via make_request_context(), exactly like every other NATS
  handler in the composing service — no bespoke auth channel.
end note

@enduml
